const puppeteer = require('puppeteer');
const fs = require('fs');

// Load the app definitions from your JSON file
const APPS = JSON.parse(fs.readFileSync('shopifyApps.json', 'utf8'));

/**
 * Gets the list of domains/fingerprints for a specific app,
 * handling the different structures in your JSON.
 */
function getAppFingerprints(appData) {
  if (Array.isArray(appData)) {
    return appData; // Structure: "AppName": ["domain1.com", "domain2.com"]
  }
  if (appData.fingerprints) {
    return appData.fingerprints; // Structure: "AppName": { "fingerprints": [...] }
  }
  if (appData.domains) {
    return appData.domains; // Structure: "AppName": { "domains": [...] }
  }
  return []; // No recognizable domains
}

async function scanShopifySite(url) {
  let browser;
  console.log(`Starting scan for: ${url}`);
  try {
    browser = await puppeteer.launch({
      headless: true, // Run in the background
      args: ['--no-sandbox', '--disable-setuid-sandbox']
    });

    const page = await browser.newPage();
    await page.setUserAgent('Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36');
    await page.setViewport({ width: 1280, height: 800 });

    // Go to the page and wait until all network activity has settled
    await page.goto(url, {
      waitUntil: 'networkidle0', // This is key for capturing all app scripts
      timeout: 35000 // 35-second timeout
    });

    // --- Performance Data Collection ---

    // 1. Get all resource timings from the browser's Performance API
    const resourceTimings = await page.evaluate(() =>
      window.performance.getEntriesByType('resource').map(entry => ({
        name: entry.name, // The full URL of the resource
        duration: entry.duration, // Load time in milliseconds
        initiatorType: entry.initiatorType, // e.g., 'script', 'css'
        transferSize: entry.transferSize // Size in bytes
      }))
    );

    // 2. Get overall page navigation timings
    const navigationTiming = await page.evaluate(() => {
      const navEntry = window.performance.getEntriesByType('navigation')[0];
      if (!navEntry) return null;
      return {
        totalPageLoadMs: navEntry.loadEventEnd,
        domContentLoadedMs: navEntry.domContentLoadedEventEnd,
        timeToFirstByteMs: navEntry.responseStart
      };
    });

    // 3. Get high-level Puppeteer metrics (like JS execution time)
    const performanceMetrics = await page.metrics();

    // --- App Correlation ---

    const detectedApps = {};

    // Loop over every app in our JSON file
    for (const [appName, appData] of Object.entries(APPS)) {
      if (appName.startsWith('//')) continue; // Skip comments

      const fingerprints = getAppFingerprints(appData);
      if (fingerprints.length === 0) continue;

      const appResources = [];
      let totalAppLoadTime = 0;
      let totalAppTransferSize = 0;

      // Loop over every resource loaded by the page
      for (const resource of resourceTimings) {
        // Check if the resource URL matches any of the app's fingerprints
        const foundFingerprint = fingerprints.find(domain => resource.name.includes(domain));

        if (foundFingerprint) {
          appResources.push(resource);
          totalAppLoadTime += resource.duration;
          totalAppTransferSize += resource.transferSize;
        }
      }

      // If we found any matching resources, add this app to our report
      if (appResources.length > 0) {
        detectedApps[appName] = {
          icon_url: appData.icon_url || null,
          resourceCount: appResources.length,
          totalLoadTimeMs: totalAppLoadTime,
          totalTransferSizeKb: totalAppTransferSize / 1024,
          // You can include the full resource list for detailed debugging
          // resources: appResources 
        };
      }
    }

    // --- Final Report Generation ---

    const finalReport = {
      scannedUrl: url,
      scanTimestamp: new Date().toISOString(),
      generalMetrics: {
        ...navigationTiming,
        totalJsExecutionTimeMs: performanceMetrics.TaskDuration * 1000, // TaskDuration is in seconds
        totalResourceCount: resourceTimings.length,
        totalPageTransferSizeKb: resourceTimings.reduce((acc, res) => acc + res.transferSize, 0) / 1024,
      },
      appPerformance: detectedApps
    };

    return finalReport;

  } catch (error) {
    console.error(`Error scanning ${url}:`, error.message);
    return {
      error: `Failed to scan ${url}: ${error.message}`
    };
  } finally {
    if (browser) {
      await browser.close();
    }
  }
}

// --- How to Run It ---

(async () => {
  // --- !!! CHANGE THIS URL !!! ---
  const urlToScan = 'https://www.gymshark.com/'; // Example: A popular Shopify store

  // 1. Run the scan
  const report = await scanShopifySite(urlToScan);

  // 2. Print the full JSON report (you could save this to a file)
  console.log(JSON.stringify(report, null, 2));

  // 3. Print a human-readable summary
  if (report.generalMetrics) {
    console.log("\n--- Scan Summary ---");
    console.log(`URL: ${report.scannedUrl}`);
    console.log(`Total Page Load: ${report.generalMetrics.totalPageLoadMs.toFixed(2)} ms`);
    console.log(`Total JS Execution: ${report.generalMetrics.totalJsExecutionTimeMs.toFixed(2)} ms`);
    console.log(`Total Page Size: ${report.generalMetrics.totalPageTransferSizeKb.toFixed(2)} KB`);

    console.log(`\nDetected ${Object.keys(report.appPerformance).length} apps with performance impact:`);
    
    // Sort apps by their load time, heaviest first
    const sortedApps = Object.entries(report.appPerformance)
      .sort(([, a], [, b]) => b.totalLoadTimeMs - a.totalLoadTimeMs);

    for (const [appName, data] of sortedApps) {
      console.log(`  - ${appName}:`);
      console.log(`    - Impact: ${data.totalLoadTimeMs.toFixed(2)} ms`);
      console.log(`    - Resources: ${data.resourceCount}`);
      console.log(`    - Size: ${data.totalTransferSizeKb.toFixed(2)} KB`);
    }
  }
})();